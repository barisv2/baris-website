---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tags = ['All', 'Essay', 'Note', 'Idea'];
---

<html lang="en">
  <head>
    <BaseHead title="Writing · Barış Gürbüzler" description="Essays, notes, and ideas on products, privacy, and building." />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1 class="page-title">Writing</h1>
        <p class="page-subtitle">Essays, notes, and half-formed ideas.</p>
      </div>

      <div class="tag-filters">
        {tags.map(tag => (
          <button class={`tag-filter ${tag === 'All' ? 'active' : ''}`} data-tag={tag}>
            {tag}
          </button>
        ))}
      </div>

      <div id="post-list">
        {allPosts.map(post => {
          const postTag = post.data.tags?.[0] ?? 'Essay';
          const tagClass = postTag.toLowerCase();
          return (
            <a href={`/blog/${post.slug}/`} class="post-card" data-tag={postTag}>
              {post.data.heroImage && (
                <div class="post-card-image">
                  <img src={post.data.heroImage} alt={post.data.title} />
                </div>
              )}
              <div class={`post-card-body ${!post.data.heroImage ? 'no-image' : ''}`}>
                <div class="post-card-top">
                  <span class={`tag tag-${tagClass}`}>{postTag}</span>
                  <span class="post-card-meta">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="post-card-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="post-card-excerpt">{post.data.description}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .tag-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .tag-filter {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 14px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .tag-filter:hover { color: var(--text); border-color: var(--text); }

  .tag-filter.active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  /* CARD */
  .post-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.15s ease;
  }

  .post-card:first-of-type { border-top: 1px solid var(--border); }
  .post-card:hover { opacity: 0.75; }

  .post-card-image {
    width: 120px;
    height: 90px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    background: var(--border);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
  }

  .post-card-body.no-image {
    justify-content: flex-start;
  }

  .post-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-card-meta {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .post-card-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
    margin: 0;
  }

  .post-card-excerpt {
    font-size: 0.82rem;
    color: var(--subtle);
    line-height: 1.6;
    margin: 0;
  }

  /* MOBILE */
  @media (max-width: 480px) {
    .post-card { flex-direction: column; }
    .post-card-image { width: 100%; height: 180px; }
  }
</style>

<script>
  const filters = document.querySelectorAll('.tag-filter');
  const cards   = document.querySelectorAll('.post-card');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const selected = (btn as HTMLButtonElement).dataset.tag;
      cards.forEach(card => {
        const show = selected === 'All' || (card as HTMLElement).dataset.tag === selected;
        (card as HTMLElement).style.display = show ? 'flex' : 'none';
      });
    });
  });
</script>
