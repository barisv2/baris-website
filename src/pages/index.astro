---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const randomPost = posts[Math.floor(Math.random() * posts.length)];
---

<html lang="en">
  <head>
    <BaseHead title="Barış Gürbüzler" description="Co-founder of Hardal. Writing about my journey as a startup co-founder and whatever I'm interested in at the moment." />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="hero-title">
        I don't know a lot of things. Here's what I'm finding out.
      </h1>
      <p class="hero-bio">
        Building <a href="https://usehardal.com" target="_blank">Hardal</a>. 
        Writing about my journey as a startup co-founder and whatever I'm interested in at the moment.
      </p>

      {randomPost && (
        <p class="random-read">
          Not sure where to start? Try <a href={`/writing/${randomPost.id.replace('.md', '')}/`}>{randomPost.data.title}</a>.
        </p>
      )}

      <p class="section-label">Recent writing</p>
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <div class="post-left">
              <a href={`/writing/${post.id.replace('.md', '')}/`}>{post.data.title}</a>
              <span class={`tag ${post.data.tags?.includes('note') ? 'tag-note' : 'tag-essay'}`}>
                {post.data.tags?.includes('note') ? 'Note' : 'Essay'}
              </span>
            </div>
            <span class="post-date">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </span>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>

<style>
  .random-read {
    font-size: 0.88rem;
    color: var(--muted);
    margin-bottom: 3rem;
  }

  .random-read a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .random-read a:hover {
    color: var(--accent);
  }
</style>
