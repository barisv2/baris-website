---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<html lang="en">
  <head>
    <BaseHead title="Barış Gürbüzler" description="Co-founder Hardal. Writing about anything I'm interested in at that moment." />
  </head>
  <body>
    <Header />
    <main>
      <p class="eyebrow">Barcelona · Co-founder, Hardal</p>
      <h1 class="hero-title">
        I don't know a lot<br />
        of things. Here's what<br />
        <em>I'm finding out.</em>
      </h1>
      <p class="hero-bio">
        Building <a href="https://usehardal.com" target="_blank">Hardal</a>. Writing about my journey as a startup founder or anything I'm interested in at that moment.
      </p>

      <p class="section-label">Recent writing</p>
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <div class="post-left">
              href={`/blog/${post.id.replace('.md', '')}/`}
              <span class={`tag ${post.data.tags?.includes('note') ? 'tag-note' : 'tag-essay'}`}>
                {post.data.tags?.includes('note') ? 'Note' : 'Essay'}
              </span>
            </div>
            <span class="post-date">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </span>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
